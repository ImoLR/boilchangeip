# Boil.network 换 IP 工具配置模板
# 用法: 复制本文件为 config.env 后填入真实值(config.env 已被 .gitignore 忽略)
#   cp config.env.example config.env

# 新版 API 使用 Token 授权；一个新版 token 对应一台 VPS。
# 多台 VPS 请配置多个对象。server id 必须稳定，且不得包含 token、IP、邮箱、
# 账号等敏感信息。
BOIL_SERVERS='[
  {
    "id": "hk-01",
    "name": "Hong Kong 01",
    "token": "replace-with-real-token",
    "enabled": true,
    "timer": {
      "enabled": true,
      "cron": "0 0 */6 * * *"
    }
  },
  {
    "id": "jp-01",
    "name": "Japan 01",
    "token": "replace-with-real-token",
    "enabled": true
  }
]'

# Telegram Bot 配置(可选)
TG_TOKEN='your-bot-token'
TG_CHAT_ID='your-chat-id'

# 已废弃: 旧版账号密码、router_id/interface 配置不再作为当前推荐配置。
# 当前 Rust 主路径不再使用它们调用旧 /login、/api/query_all、/api/reconnect。
# BOIL_ACCOUNT='your-account@example.com'
# BOIL_PASSWORD='your-password'
# BOIL_ROUTER_ID='182'
# BOIL_INTERFACE='adsl3'
